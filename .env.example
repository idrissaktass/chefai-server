# ===== DATABASE =====
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-recipe?retryWrites=true&w=majority

# ===== JWT =====
JWT_SECRET=your-secret-key-here-min-32-characters

# ===== OPENAI (Required for Coach AI) =====
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ===== SERVER =====
PORT=8080
NODE_ENV=production

# ===== FIREBASE (for authentication) =====
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# ===== REVENUE CAT (for premium features) =====
REVENUE_CAT_API_KEY=your-revenue-cat-key

# ===== FRONTEND BASE URL =====
VITE_API_URL=https://chefai-server.onrender.com
